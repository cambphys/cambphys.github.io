source "https://rubygems.org"

# Jekyll + plugins used by the Minimal Mistakes theme. The theme's own files
# (_layouts, _includes, _sass, _data) live in the repo root, so we don't need
# `gemspec` (which trips Bundler's US-ASCII default on Vercel's build image).
gem "jekyll", ">= 3.7", "< 5.0"
gem "jekyll-paginate", "~> 1.1"
gem "jekyll-sitemap", "~> 1.3"
gem "jekyll-gist", "~> 1.5"
gem "jekyll-feed", "~> 0.1"
gem "jekyll-include-cache", "~> 0.1"
